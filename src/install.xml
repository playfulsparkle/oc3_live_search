<modification>
    <name>Playful Sparkle - Live Search</name>
    <code>ps_live_search</code>
    <version>1.0.5</version>
    <author>Playful Sparkle</author>
    <link>https://github.com/playfulsparkle/oc3_live_search</link>
    <file path="catalog/controller/common/header.php">
        <operation>
            <search><![CDATA[$data['analytics'] = array();]]></search>
            <add position="before"><![CDATA[
                if ($this->config->get('module_ps_live_search_status')) {
                    $this->document->addScript('catalog/view/javascript/ps_live_search.js');
                    $this->document->addStyle('catalog/view/theme/default/stylesheet/ps_live_search.css');
                }
            ]]></add>
        </operation>
    </file>
    <file path="catalog/controller/common/search.php">
        <operation>
            <search><![CDATA[$this->language->get('text_search');]]></search>
            <add position="after"><![CDATA[
                if ($this->config->get('module_ps_live_search_status')) {
                    $this->load->language('extension/module/ps_live_search', 'ps_live_search');

                    $ps_language = $this->language->get('ps_live_search');

                    $data['ps_heading_products'] = $ps_language->get('heading_products');
                    $data['ps_heading_categories'] = $ps_language->get('heading_categories');
                    $data['ps_heading_manufacturers'] = $ps_language->get('heading_manufacturers');
                    $data['ps_heading_informations'] = $ps_language->get('heading_informations');
                    $data['ps_text_showing_results'] = $ps_language->get('text_showing_results');
                    $data['ps_text_all_product_results'] = $ps_language->get('text_all_product_results');
                    $data['ps_text_no_results'] = $ps_language->get('text_no_results');

                    $data['ps_input_delay'] = (int) $this->config->get('module_ps_live_search_input_delay');
                    $data['ps_input_min_chars'] = (int) $this->config->get('module_ps_live_search_input_min_chars');
                }
            ]]></add>
        </operation>
    </file>
    <file path="catalog/view/theme/default/template/common/search.twig">
        <operation>
            <search position="after"><![CDATA[id="search" class="]]></search>
            <add><![CDATA[id="search" class="ps-live-search-container ]]></add>
        </operation>
    </file>
    <file path="catalog/view/theme/default/template/common/search.twig">
        <operation>
            <search position="after"><![CDATA[name="search"]]></search>
            <add><![CDATA[name="search" id="ps-live-search-input" data-live-search-target="ps-live-search"]]></add>
        </operation>
    </file>
    <file path="catalog/view/theme/default/template/common/search.twig">
        <operation>
            <search><![CDATA[</div>]]></search>
            <add position="before"><![CDATA[
            <ul id="ps-live-search" class="ps-live-search-list"></ul>
            <script>
                $('#ps-live-search-input').pslivesearch({
                    source: function (request, response) {
                        $.ajax({
                            url: 'index.php?route=extension/module/ps_live_search/autocomplete&search=' + encodeURIComponent(request),
                            dataType: 'json',
                            cache: false,
                            success: function (json) {
                                response(json);
                            }
                        });
                    },
                    translations: {
                        heading_products: '{{ ps_heading_products }}',
                        heading_categories: '{{ ps_heading_categories }}',
                        heading_manufacturers: '{{ ps_heading_manufacturers }}',
                        heading_informations: '{{ ps_heading_informations }}',
                        text_showing_results: '{{ ps_text_showing_results }}',
                        text_all_product_results: '{{ ps_text_all_product_results }}',
                        text_no_results: '{{ ps_text_no_results }}',
                    },
                    options: {
                        input_delay: {{ ps_input_delay | default(100) }},
                        input_min_chars: {{ ps_input_min_chars | default(1) }}
                    }
                });
            </script>
            ]]></add>
        </operation>
    </file>
</modification>
